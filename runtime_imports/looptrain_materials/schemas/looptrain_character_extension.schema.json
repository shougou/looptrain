{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LoopTrain Character Extension",
  "type": "object",
  "required": [
    "schema_version",
    "npc_id",
    "role_type",
    "visibility"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "npc_id": {
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "role_type": {
      "type": "string"
    },
    "visibility": {
      "type": "string",
      "enum": [
        "visible",
        "hidden"
      ]
    },
    "dialogue_ap_cost": {
      "type": "integer"
    },
    "portrait_assets": {
      "type": "object"
    },
    "initial_states": {
      "type": "object"
    },
    "knows": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "does_not_know": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "release_rules": {
      "type": "array"
    },
    "hard_constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}