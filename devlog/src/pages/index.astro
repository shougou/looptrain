---
/** Homepage `/` — Hero + Status + Recent Devlog + Roadmap Summary */
import Layout from '../components/Layout.astro';
import Hero from '../components/Hero.astro';
import StatusCard from '../components/StatusCard.astro';
import DevlogCard from '../components/DevlogCard.astro';
import KnownIssue from '../components/KnownIssue.astro';
import { SITE_DESCRIPTION } from '../data/site';
import { getCollection } from 'astro:content';
import siteStatus from '../data/site-status.json';
import { sortByPinnedThenDate } from '../lib/contentSort';

const SLUG_RE = /^\d{4}-\d{2}-\d{2}-/;
const devlogs = await getCollection('devlog');
const sorted = sortByPinnedThenDate(devlogs)
  .slice(0, 3)
  .map((entry) => ({
    slug: entry.id.replace(SLUG_RE, ''),
    title: entry.data.title,
    date: entry.data.date.toISOString().slice(0, 10),
    summary: entry.data.summary,
    tags: entry.data.tags,
    status: entry.data.status,
    pinned: entry.data.pinned,
  }));

const play = siteStatus.play;
const site = siteStatus.site;

const recentIssues = play.knownIssues.slice(0, 3);
---

<Layout
  title="LoopTrain 开发日志"
  description={SITE_DESCRIPTION}
  canonicalURL="/"
>
  <Hero version={play.currentVersion} playUrl={play.playUrl} />

  <div class="l-content-wide" style="margin-top: var(--space-8)">
    <StatusCard
      version={play.currentVersion}
      phase={site.currentPhase}
      lastUpdated={site.lastUpdated}
      nextFocus={site.nextFocus}
      issueCount={play.knownIssues.length}
      stageDescription={play.stageDescription}
    />
  </div>

  <!-- Why -->
  <section class="section l-content-wide">
    <h2 class="section-title">不只是游戏</h2>
    <p class="why-text">
      LoopTrain 对我来说，只是因为好奇，因为好玩，因为一切我说了算，因为我想亲自去探索一个问题：当 AI 成为开发者真正的协作者之后，软件开发最终会演变成什么样子？
    </p>
    <p class="why-text">
      在这里，我没有项目压力，没有商业目标，也不需要迎合任何用户。我可以完全按照自己的兴趣，从零开始构建，也可以随时推翻重来。每一次重构、每一次失败、每一次架构调整，都是一次真实的实验。
    </p>
    <p class="why-text">
      游戏只是实验的载体，而不是最终目的。我更关心的是人与 AI 如何协作、状态如何管理、Agent 如何组织、Prompt 如何设计、复杂系统如何保持可控，以及 AI Coding 的能力边界究竟在哪里。
    </p>
    <p class="why-text">
      我希望把整个探索过程完整地记录下来，包括成功的方法，也包括错误的尝试；包括技术实现，也包括思考过程；包括最终的方案，更包括为什么放弃曾经的方案。
    </p>
    <p class="why-text">
      对我而言，这些开发日志、技术总结、经验和教训，远比游戏本身更有价值。它们不仅记录了一个项目的成长，也记录了一个开发者在 AI 时代重新学习软件工程、重新理解架构设计、重新定义开发方式的全过程。
    </p>
  </section>

  <!-- Recent Devlog -->
  <section class="section l-content-wide">
    <div class="section-header">
      <h2 class="section-title">最近开发日志</h2>
      <a href="/devlog" class="section-link">查看全部 →</a>
    </div>
    <div class="devlog-grid">
      {sorted.map((entry) => (
            <DevlogCard
              slug={entry.slug}
              title={entry.title}
              date={entry.date}
              summary={entry.summary}
              tags={entry.tags}
               status={entry.status}
               pinned={entry.pinned}
            />
          ))}
    </div>
  </section>

  <!-- Roadmap Summary -->
  <section class="section l-content-wide">
    <div class="section-header">
      <h2 class="section-title">当前路线</h2>
      <a href="/roadmap" class="section-link">查看完整路线图 →</a>
    </div>
    <p class="roadmap-summary">
      当前阶段「{site.currentPhase}」：修复移动端体验问题，梳理游戏结构，建立最小可用试玩闭环。下一步将进入「体验增强」阶段，增加音效系统、完善 NPC 时间线和角色对话状态。
    </p>
  </section>

  <!-- Known Issues -->
  <section class="section l-content-wide">
    <div class="section-header">
      <h2 class="section-title">已知问题</h2>
      <span class="section-subtitle">{play.knownIssues.length} 项</span>
    </div>
    <div class="issues-list">
      {recentIssues.map((issue, i) => (
        <KnownIssue
          title={issue}
          priority={i === 0 ? 'high' : 'medium'}
        />
      ))}
      {play.knownIssues.length > 3 && (
        <a href="/play" class="issues-more">
          查看全部 {play.knownIssues.length} 项已知问题 →
        </a>
      )}
    </div>
  </section>
</Layout>

<style>
  .section {
    margin-top: var(--space-10);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-4);
  }

  .section-title {
    font-size: 18px;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
  }

  .section-subtitle {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-text-subtle);
  }

  .section-link {
    font-size: 14px;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .section-link:hover {
    color: var(--color-accent);
  }

  .devlog-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .roadmap-summary {
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin: 0;
    max-width: 680px;
  }

  .why-text {
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.9;
    margin: 0 0 var(--space-3);
    max-width: 680px;
  }

  .issues-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .issues-more {
    display: inline-block;
    font-size: 13px;
    color: var(--color-text-muted);
    margin-top: var(--space-2);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .issues-more:hover {
    color: var(--color-accent);
  }

  @media (min-width: 768px) {
    .devlog-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-5);
    }
  }
</style>
