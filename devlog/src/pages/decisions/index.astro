---
import Layout from '../../components/Layout.astro';
import DocCard from '../../components/DocCard.astro';
import { getCollection } from 'astro:content';
import { sortByPinnedThenDate } from '../../lib/contentSort';

const docs = sortByPinnedThenDate(
  (await getCollection('decisions')).filter((entry) => entry.data.status !== 'planned')
).map((entry) => ({
  href: `/decisions/${entry.id}`,
  title: `${entry.data.decisionId}: ${entry.data.title}`,
  date: entry.data.date.toISOString().slice(0, 10),
  summary: entry.data.summary,
  tags: entry.data.tags,
  status: entry.data.status,
  scope: entry.data.scope,
  spoilerLevel: entry.data.spoilerLevel,
  pinned: entry.data.pinned,
}));
---

<Layout
  title="决策记录"
  description="LoopTrain 的重要架构、流程和项目治理决策记录。"
  canonicalURL="/decisions"
>
  <div class="l-content-wide">
    <section class="page-header">
      <h1 class="page-title">决策记录</h1>
      <p class="page-desc">
        记录重要选择的背景、取舍和后果。这里回答“为什么这样做”，而不是只记录“做了什么”。
      </p>
    </section>

    <a href="/docs" class="back-link">← 返回文档库</a>

    <div class="doc-list">
      {docs.map((doc) => <DocCard {...doc} />)}
    </div>
  </div>
</Layout>

<style>
  .page-header { margin-top: var(--space-10); margin-bottom: var(--space-8); }
  .page-title { font-size: 24px; font-weight: 700; margin: 0 0 var(--space-2); }
  .page-desc { font-size: 14px; color: var(--color-text-muted); margin: 0; }
  .back-link { display: inline-block; margin-bottom: var(--space-5); color: var(--color-text-muted); font-size: 14px; }
  .doc-list { display: flex; flex-direction: column; gap: var(--space-4); }
  @media (min-width: 768px) { .doc-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-5); } }
</style>
