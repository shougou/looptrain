---
/** Layout — global layout shell with BaseHead, Header, Footer */
import '../styles/global.css';
import BaseHead from './BaseHead.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalURL?: string;
}

const {
  title,
  description,
  ogImage,
  canonicalURL,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <BaseHead
      title={title}
      description={description}
      ogImage={ogImage}
      canonicalURL={canonicalURL}
    />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
