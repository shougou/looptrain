---
/** StatusCard — homepage current project status snapshot */
import VersionBadge from './VersionBadge.astro';

export interface Props {
  version: string;
  phase: string;
  lastUpdated: string;
  nextFocus: string;
  issueCount: number;
  stageDescription: string;
}

const { version, phase, lastUpdated, nextFocus, issueCount, stageDescription } =
  Astro.props;
---

<section class="status-card">
  <h2 class="status-title">当前状态</h2>
  <div class="status-grid">
    <div class="status-item">
      <span class="status-label">当前版本</span>
      <span class="status-value"><VersionBadge version={version} /></span>
    </div>
    <div class="status-item">
      <span class="status-label">当前阶段</span>
      <span class="status-value">{phase}</span>
    </div>
    <div class="status-item">
      <span class="status-label">最近更新</span>
      <span class="status-value status-mono">{lastUpdated}</span>
    </div>
    <div class="status-item">
      <span class="status-label">已知问题</span>
      <span class="status-value">{issueCount} 项</span>
    </div>
  </div>
  <div class="status-item status-item-full">
    <span class="status-label">下一步重点</span>
    <span class="status-value">{nextFocus}</span>
  </div>
  <p class="status-desc">{stageDescription}</p>
</section>

<style>
  .status-card {
    background: var(--color-bg-panel);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
  }

  .status-title {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 var(--space-4);
    color: var(--color-text);
  }

  .status-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3) var(--space-4);
    margin-bottom: var(--space-3);
  }

  .status-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .status-item-full {
    margin-top: var(--space-2);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border-soft);
  }

  .status-label {
    font-size: 12px;
    color: var(--color-text-muted);
  }

  .status-value {
    font-size: 15px;
    color: var(--color-text);
    line-height: 1.5;
  }

  .status-mono {
    font-family: var(--font-mono);
    font-size: 13px;
  }

  .status-desc {
    font-size: 13px;
    color: var(--color-text-muted);
    margin: var(--space-3) 0 0;
    line-height: 1.6;
  }

  @media (min-width: 768px) {
    .status-grid {
      grid-template-columns: repeat(4, 1fr);
    }

    .status-item-full {
      grid-column: 1 / -1;
    }

    .status-value {
      font-size: 16px;
    }
  }
</style>
