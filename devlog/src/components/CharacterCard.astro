---
/** CharacterCard — public NPC archive card.
 *  Spoiler-safe: only shows info available on first encounter.
 *  For locked characters: shows placeholder only.
 */

export interface Props {
  displayName: string;
  publicRole: string;
  playtestStatus: string;
  cardSourceStatus: string;
  tags: string[];
  summary: string;
  publicNotes?: string;
  locked?: boolean;
  portraitAsset?: string;
}

const {
  displayName,
  publicRole,
  playtestStatus,
  cardSourceStatus,
  tags,
  summary,
  publicNotes,
  locked = false,
  portraitAsset,
} = Astro.props;

const statusLabel: Record<string, string> = {
  'in-playtest': '试玩版中',
  planned: '计划中',
  partial: '部分实现',
};

const statusColor: Record<string, string> = {
  'in-playtest': 'var(--color-success)',
  planned: 'var(--color-warning)',
  partial: 'var(--color-text-muted)',
};

const sourceLabel: Record<string, string> = {
  ai_generated: 'AI 生成',
  待确认: '待确认',
  已确认: '已确认',
};

const sourceColor: Record<string, string> = {
  ai_generated: 'var(--color-text-muted)',
  待确认: 'var(--color-warning)',
  已确认: 'var(--color-success)',
};

const psLabel = statusLabel[playtestStatus] || playtestStatus;
const psColor = statusColor[playtestStatus] || 'var(--color-text-muted)';
const csLabel = sourceLabel[cardSourceStatus] || cardSourceStatus;
const csColor = sourceColor[cardSourceStatus] || 'var(--color-text-muted)';
---

<article class={`character-card ${locked ? 'locked' : ''}`}>
  <!-- Portrait area -->
  <div class="card-portrait" aria-label={`${displayName} 的立绘区域`}>
    {
      locked ? (
        <span class="portrait-placeholder">🔒</span>
      ) : portraitAsset ? (
        <img
          src={portraitAsset}
          alt={`${displayName} 的立绘`}
          class="portrait-img"
          loading="lazy"
        />
      ) : (
        <span class="portrait-placeholder">立绘待确认</span>
      )
    }
  </div>

  <!-- Info area -->
  <div class="card-body">
    <h3 class="card-name">{displayName}</h3>
    <div class="card-divider" aria-hidden="true"></div>

    <p class="card-role">
      {locked ? '隐藏节点' : publicRole}
      <span class="card-playtest-status" style={`color: ${psColor}`}>
        {locked ? '暫不公开' : psLabel}
      </span>
    </p>

    {
      !locked && (
        <>
          <div class="card-tags">
            <span
              class="card-meta-tag"
              style={`color: ${csColor}`}
            >
              {csLabel}
            </span>
            {tags.map((t) => (
              <span class="card-meta-tag">{t}</span>
            ))}
          </div>

          <p class="card-summary">{summary}</p>

          {publicNotes && (
            <p class="card-notes">{publicNotes}</p>
          )}
        </>
      )
    }

    {locked && (
      <p class="card-notes locked-note">
        该角色信息暂不公开。隐藏设定请在游戏中自行发现。
      </p>
    )}
  </div>
</article>

<style>
  .character-card {
    background: var(--color-bg-panel);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.02);
  }

  .card-portrait {
    height: 200px;
    background: var(--color-bg-elevated);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .portrait-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: linear-gradient(
      to bottom,
      transparent 60%,
      rgba(7, 9, 13, 0.4)
    );
  }

  .portrait-placeholder {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-text-subtle);
    text-align: center;
  }

  .card-body {
    padding: var(--space-4);
  }

  .card-name {
    font-size: 18px;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
  }

  .card-divider {
    height: 1px;
    background: var(--color-border-soft);
    margin: var(--space-2) 0;
  }

  .card-role {
    font-size: 14px;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-3);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .card-playtest-status {
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .card-tags {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
    margin-bottom: var(--space-3);
  }

  .card-meta-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-subtle);
    background: var(--color-bg-elevated);
    padding: 1px 8px;
    border-radius: var(--radius-sm);
  }

  .card-summary {
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0 0 var(--space-2);
  }

  .card-notes {
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
    font-style: italic;
  }

  .locked-note {
    color: var(--color-text-subtle);
  }

  @media (min-width: 768px) {
    .card-portrait {
      height: 240px;
    }
  }
</style>
