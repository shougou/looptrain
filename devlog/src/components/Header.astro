---
/** Header — global top navigation. Mobile-first with CSS-only hamburger. */
import { NAV_ITEMS } from '../data/site';

const currentPath = Astro.url.pathname;
---

<header class="header">
  <nav class="nav l-container" aria-label="主导航">
    <a href="/" class="nav-brand">LoopTrain</a>

    <!-- CSS-only hamburger toggle -->
    <input type="checkbox" id="nav-toggle" class="nav-toggle-input" />
    <label for="nav-toggle" class="nav-toggle" aria-label="菜单">
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </label>

    <ul class="nav-list">
      {
        NAV_ITEMS.map((item) => {
          const isActive =
            item.href === '/'
              ? currentPath === '/'
              : currentPath.startsWith(item.href);
          return (
            <li>
              <a
                href={item.href}
                class={isActive ? 'nav-link active' : 'nav-link'}
                aria-current={isActive ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(13, 17, 24, 0.92);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border-soft);
    height: 48px;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .nav-brand {
    font-size: 16px;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    flex-shrink: 0;
  }

  /* Hamburger */
  .nav-toggle-input {
    display: none;
  }

  .nav-toggle {
    display: flex;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 4px;
    z-index: 101;
  }

  .nav-toggle-bar {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--color-text-muted);
    border-radius: 1px;
    transition: transform var(--transition-normal),
      opacity var(--transition-normal);
  }

  .nav-toggle-input:checked ~ .nav-toggle .nav-toggle-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .nav-toggle-input:checked ~ .nav-toggle .nav-toggle-bar:nth-child(2) {
    opacity: 0;
  }

  .nav-toggle-input:checked ~ .nav-toggle .nav-toggle-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Nav list */
  .nav-list {
    list-style: none;
    margin: 0;
    display: none;
    position: fixed;
    top: 48px;
    left: 0;
    right: 0;
    height: calc(100vh - 48px);
    background:
      linear-gradient(180deg, rgba(7, 9, 13, 0.98), rgba(7, 9, 13, 0.96)),
      var(--color-bg);
    border-top: 1px solid var(--color-border-soft);
    flex-direction: column;
    padding: var(--space-5);
    gap: var(--space-2);
    z-index: 99;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
  }

  .nav-toggle-input:checked ~ .nav-list {
    display: flex;
  }

  .nav-link {
    display: block;
    padding: var(--space-3) var(--space-4);
    color: var(--color-text);
    font-size: 16px;
    font-weight: 500;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border-soft);
    background: var(--color-bg-panel);
    transition: color var(--transition-fast),
      background var(--transition-fast),
      border-color var(--transition-fast);
    text-decoration: none;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--color-accent);
    background: var(--color-bg-panel);
  }

  .nav-link.active {
    color: var(--color-accent);
    background: var(--color-accent-soft);
  }

  /* Desktop: horizontal nav */
  @media (min-width: 768px) {
    .header {
      height: 56px;
    }

    .nav-toggle {
      display: none;
    }

    .nav-list {
      display: flex;
      position: static;
      flex-direction: row;
      height: auto;
      background: transparent;
      border-top: 0;
      box-shadow: none;
      padding: 0;
      gap: var(--space-1);
      align-items: center;
    }

    .nav-link {
      font-size: 14px;
      padding: var(--space-1) var(--space-3);
      color: var(--color-text-muted);
      border-color: transparent;
      background: transparent;
    }

    .nav-link.active {
      background: transparent;
    }
  }
</style>
