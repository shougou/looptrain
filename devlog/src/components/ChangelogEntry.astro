---
/** ChangelogEntry — a single changelog version block */
export interface Props {
  version: string;
  date: string;
  children: any;
}

const { version, date } = Astro.props;
---

<article class="changelog-entry">
  <header class="entry-header">
    <span class="entry-version">{version}</span>
    <time class="entry-date" datetime={date}>日期：{date}</time>
  </header>
  <div class="entry-body">
    <slot />
  </div>
</article>

<style>
  .changelog-entry {
    background: var(--color-bg-panel);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
  }

  .entry-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border-soft);
  }

  .entry-version {
    font-family: var(--font-mono);
    font-size: 16px;
    font-weight: 600;
    color: var(--color-accent);
  }

  .entry-date {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-text-muted);
  }

  .entry-body :global(h3) {
    font-size: 14px;
    color: var(--color-text-muted);
    font-weight: 600;
    text-transform: none;
    margin: var(--space-3) 0 var(--space-2);
  }

  .entry-body :global(h3:first-child) {
    margin-top: 0;
  }

  .entry-body :global(ul) {
    padding-left: 1.2em;
    margin-bottom: var(--space-3);
  }

  .entry-body :global(li) {
    font-size: 14px;
    color: var(--color-text);
    line-height: 1.7;
  }
</style>
