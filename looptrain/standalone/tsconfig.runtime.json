{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": "./src/runtime",
    "outDir": "./dist/runtime",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/runtime/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
